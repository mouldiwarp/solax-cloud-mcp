# SolaX Cloud API token (required)
# Obtain from https://www.solaxcloud.com/user-center/ → Service → API
SOLAX_TOKEN_ID=

# WiFi/communication dongle registration number (optional)
# If set, this device will be queried by default when get_realtime_data is called with no wifi_sn
# If not set, wifi_sn must be passed to each tool call
SOLAX_WIFI_SN=
