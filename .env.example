# SolaX Developer Platform OAuth2 client ID (required)
# Register an OAuth2 application at https://developer.solaxcloud.com/
# and obtain from the Application page
SOLAX_CLIENT_ID=

# SolaX Developer Platform OAuth2 client secret (required)
# Register an OAuth2 application at https://developer.solaxcloud.com/
# and obtain from the Application page
SOLAX_CLIENT_SECRET=

# Device (inverter) serial number (optional)
# The inverter's SN, NOT the old WiFi dongle registration number
# If set, this device will be queried by default when get_realtime_data is called with no device_sn
# If not set, device_sn must be passed to each tool call
SOLAX_DEVICE_SN=

# HTTP Server Configuration (only used when TRANSPORT=http)
# ============================================================

# Bearer token for HTTP API authentication (required for HTTP mode)
# Generate a strong random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
HTTP_API_KEY=

# HTTP server host (optional, default: 0.0.0.0)
HTTP_HOST=0.0.0.0

# HTTP server port (optional, default: 8000)
HTTP_PORT=8000

# Transport mode: "stdio" for MCP (default) or "http" for HTTP server
# TRANSPORT=http
